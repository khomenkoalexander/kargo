# Copy this file to .env and edit before running docker compose.
# .env is git-ignored; never commit real secrets.

# ── Required ────────────────────────────────────────────────────────────────
# Shared bearer token — set the same value on the server and in every CLI config.
KFILE_BEARER_TOKEN=change-me

# ── Kafka data volume (bundled mode) ────────────────────────────────────────
# Host path that the Kafka broker mounts for topic data.
# Default is a bind-mount at ./kafka-data (easy to inspect or delete during dev).
KFILE_KAFKA_DATA=./kafka-data

# ── External Kafka (external-kafka compose only) ────────────────────────────
# Bootstrap servers for a pre-existing Kafka cluster.
# Not used in bundled mode (kafka:9092 is wired in docker-compose.yml directly).
# KFILE_KAFKA_BOOTSTRAP=kafka.example.com:9092

# ── Topic names ─────────────────────────────────────────────────────────────
# Override only if your cluster already uses these names for something else.
# KFILE_INFO_TOPIC=xfer.info
# KFILE_DATA_TOPIC=xfer.data

# ── Concurrency ─────────────────────────────────────────────────────────────
# Number of partitions on xfer.data — sets the concurrent-transfer ceiling.
# Must match the value used when the topic was created (kafka-init.sh default: 6).
# KFILE_DATA_PARTITIONS=6

# Maximum chunk size the backend accepts from senders (bytes).
# Must not exceed the broker's max.message.bytes (default: 4 MB).
# KFILE_MAX_CHUNK_BYTES=4194304

# Default sliding-window size (max in-flight chunks per transfer).
# KFILE_WINDOW=10

# ── Backend networking ───────────────────────────────────────────────────────
# KFILE_BACKEND_PORT=8080

# ── TTL / timing ─────────────────────────────────────────────────────────────
# Seconds before an unmatched offer is expired.
# KFILE_TTL_OFFER=1800

# Seconds before a paused/idle transfer is aborted.
# KFILE_TTL_TRANSFER=3600

# Seconds of chunk inactivity before an accepted/in-progress transfer is aborted.
# KFILE_TTL_ORPHAN=60

# SSE heartbeat interval in seconds.
# KFILE_SSE_HEARTBEAT=15
